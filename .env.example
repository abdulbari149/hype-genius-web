# =============================================================================
# HypeGenius web (Next.js) — environment variables
# =============================================================================
# Copy to .env.local for local overrides (recommended), or rely on Next.js
# loading .env.development / .env.production by NODE_ENV.
#
# Vercel: Project → Settings → Environment Variables → add the same keys.
# Use your public HTTPS API origin for Production and Preview (e.g. https://api.example.com).
# =============================================================================

# Backend API origin (no trailing slash). Exposed to the browser (NEXT_PUBLIC_*).
# Local: start the backend on the same port (see backend PORT, default 5000).
NEXT_PUBLIC_API_URL=https://backend-alpha-nine-69.vercel.app
